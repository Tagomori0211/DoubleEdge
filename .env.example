# ============================================================
# DoubleEdge — centralised secrets (.env)
#
# 使い方:
#   cp .env.example .env
#   .env を編集して DeepSeek の API キーを記入する
#   ./setup-doubleedge.sh が起動時に自動で読み込む（pane 0: DS / cline に継承）
#
# .env は .gitignore 済み。コミットしないこと。
# claude (BLADE) と agy (AG×3) はサブスクリプション/OAuth ログインのため
# ここにキーは不要。集約対象は DS（DeepSeek V4 Pro）のみ。
# ============================================================

# ── DeepSeek (pane 0: DS / cline) ───────────────────────────
# https://platform.deepseek.com/api_keys で発行
DEEPSEEK_API_KEY=

# DeepSeek は OpenAI 互換 API。通常は既定値のままでよい。
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
